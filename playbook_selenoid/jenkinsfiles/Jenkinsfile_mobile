pipeline {
    agent any

    parameters {
        choice(name: 'TEST_TYPE', choices: ['ui', 'mobile'], description: 'Тип тестов')
        string(name: 'BRANCH', defaultValue: 'main', description: 'Ветка репозитория')
        // параметры для UI
        string(name: 'BROWSER', defaultValue: 'chrome', description: 'Браузер (для UI)')
        string(name: 'BROWSER_VERSION', defaultValue: 'latest', description: 'Версия браузера')
        // параметры для Mobile
        choice(name: 'EMULATOR', choices: ['android-12', 'android-14'], description: 'Эмулятор (для Mobile)')
    }

    stages {
        stage('Checkout') {
            steps {
                git branch: "${params.BRANCH}",
                    url: 'https://github.com/dimamoryk/AutoTestWithMobileAppium.git',
                    credentialsId: 'github-credentials'
            }
        }

        stage('Start Docker Compose (Mobile)') {
            when { expression { params.TEST_TYPE == 'mobile' } }
            steps {
                sh '''
                    docker-compose up -d
                    sleep 30
                '''
            }
        }

        stage('Run Tests') {
            steps {
                script {
                    if (params.TEST_TYPE == 'ui') {
                        sh """
                            mvn clean test \
                                -Dselenoid.url=http://selenoid1:4444 \
                                -Dbrowser=${params.BROWSER} \
                                -Dbrowser.version=${params.BROWSER_VERSION}
                        """
                    } else if (params.TEST_TYPE == 'mobile') {
                        def appiumPort = (params.EMULATOR == 'android-12') ? '4723' : '4724'
                        sh """
                            mvn clean test \
                                -Dappium.port=${appiumPort} \
                                -Ddatabase.url=jdbc:postgresql://sql.otus.kartushin.su:5432/wishlist \
                                -Ddatabase.username=student \
                                -Ddatabase.password=student
                        """
                    }
                }
            }
        }

        stage('Publish Reports') {
            steps {
                publishHTML([
                    reportDir: 'target/surefire-reports',
                    reportFiles: '*.html',
                    reportName: 'Test Reports'
                ])
                junit 'target/surefire-reports/*.xml'
            }
        }
    }

    post {
        always {
            cleanWs()
        }
        failure {
            echo 'Tests failed!'
        }
        success {
            echo 'Tests passed successfully!'
        }
    }
}
